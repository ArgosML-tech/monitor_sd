# ─────────────────────────────────────────────────────────────────────────────
# Praman v1.0 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env — it is gitignored
# ─────────────────────────────────────────────────────────────────────────────

# ── SAP Connection ─────────────────────────────────────────────────────────
# Which system to use: 'cloud' or 'onprem'
SAP_ACTIVE_SYSTEM=cloud

# Cloud system (used when SAP_ACTIVE_SYSTEM=cloud)
SAP_CLOUD_BASE_URL=https://your-tenant.s4hana.cloud.sap
SAP_CLOUD_USERNAME=
SAP_CLOUD_PASSWORD=

# On-premise system (used when SAP_ACTIVE_SYSTEM=onprem)
# SAP_ONPREM_BASE_URL=https://sapserver.example.com:8443/sap/bc/ui5_ui5/
# SAP_ONPREM_USERNAME=
# SAP_ONPREM_PASSWORD=

# Auth strategy: 'btp-saml' | 'basic' | 'office365'
SAP_AUTH_STRATEGY=btp-saml
SAP_CLIENT=100
SAP_LANGUAGE=EN

# ── Praman Config Overrides ────────────────────────────────────────────────
PRAMAN_LOG_LEVEL=info
PRAMAN_INTERACTION_STRATEGY=ui5-native

# ── Telemetry (optional — only if using OpenTelemetry) ─────────────────────
# PRAMAN_TELEMETRY_ENABLED=true
# PRAMAN_TELEMETRY_ENDPOINT=http://localhost:4318
# PRAMAN_TELEMETRY_EXPORTER=otlp
# PRAMAN_TELEMETRY_SERVICE_NAME=my-sap-tests
# PRAMAN_TELEMETRY_METRICS_ENABLED=true
# PRAMAN_TELEMETRY_PROTOCOL=http
# PRAMAN_TELEMETRY_BATCH_TIMEOUT=5000
# PRAMAN_TELEMETRY_MAX_QUEUE_SIZE=2048

# Azure Monitor (alternative to OTLP — uncomment if using azure-monitor exporter)
# PRAMAN_TELEMETRY_EXPORTER=azure-monitor
# PRAMAN_TELEMETRY_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── AI Provider (optional — only if using playwright-praman/ai) ────────────
PRAMAN_AI_PROVIDER=azure-openai
PRAMAN_AI_API_KEY=
PRAMAN_AI_ENDPOINT=

# ── npm Publishing (CI only — do NOT commit actual values) ─────────────────
NPM_TOKEN=
